                        {name}
                      </span>
                      <span className="text-[9px] font-medium text-neutral-500 uppercase">
                        {meta.type}
                      </span>
                    </div>
                  );
                })}
              </div>
            </div>

            <div className="p-3 border border-dashed border-neutral-300 rounded-md bg-neutral-50/50">
              <p className="text-[11.5px] text-neutral-600 leading-relaxed">
                <strong className="text-neutral-900">Tip:</strong> Generated drafts pull from your tool list, so the more relevant tools you connect, the more grounded your policy becomes.
              </p>
            </div>
          </div>
        </aside>
      </div>

      {/* Formatting modal */}
      {showFormatting && (
        <Modal
          title="Formatting preferences"
          onClose={() => setShowFormatting(false)}
          size={showCustomRulesExpanded ? "lg" : "md"}
        >
          <p className="text-[12px] text-neutral-500 mb-4">
            These preferences shape how each section is drafted. Change anytime and regenerate.
          </p>

          <FormattingSelect
            label="Tone"
            value={formatting.tone}
            onChange={(v) => setFormatting({ ...formatting, tone: v })}
            options={["Professional", "Friendly", "Direct", "Empathetic"]}
            help="How the agent comes across to customers."
          />

          <FormattingSelect
            label="Length"
            value={formatting.length}
            onChange={(v) => setFormatting({ ...formatting, length: v })}
            options={["Concise", "Balanced", "Thorough"]}
            help="Density of generated drafts."
          />

          <FormattingSelect
            label="Probing"
            value={formatting.probing}
            onChange={(v) => setFormatting({ ...formatting, probing: v })}
            options={["Minimal", "Moderate", "Aggressive"]}
            help="How much the agent will ask before resolving or escalating."
          />

          <div className="mt-4">
            <div className="flex items-center justify-between mb-1.5">
              <label className="text-[11px] font-semibold text-neutral-500 uppercase tracking-wide">
                Custom rules
              </label>
              <button
                onClick={() => setShowCustomRulesExpanded(!showCustomRulesExpanded)}
                className="text-[11px] text-neutral-600 hover:text-neutral-900 flex items-center gap-1"
              >
                <Maximize2 className="w-3 h-3" />
                {showCustomRulesExpanded ? "Collapse" : "Expand"}
              </button>
            </div>

            {!showCustomRulesExpanded ? (
              <textarea
                value={formatting.customNotes}
                onChange={(e) =>
                  setFormatting({ ...formatting, customNotes: e.target.value })
                }
                placeholder="e.g. Always confirm customer email before issuing credit. Use bullet points for multi-step responses."
                rows={3}
                className="w-full text-[13px] border border-neutral-200 rounded-md p-2.5 focus:outline-none focus:border-neutral-900 resize-none"
              />
            ) : (
              <div className="border border-neutral-200 rounded-md overflow-hidden">
                <textarea
                  value={formatting.customNotes}
                  onChange={(e) =>
                    setFormatting({ ...formatting, customNotes: e.target.value })
                  }
                  placeholder="Add your own formatting rules, or click any common rule below to insert it."
                  rows={6}
                  className="w-full text-[13px] p-3 focus:outline-none resize-none border-b border-neutral-200"
                />

                <div className="bg-neutral-50/50 p-3">
                  <div className="text-[10.5px] font-semibold text-neutral-500 uppercase tracking-wide mb-2">
                    Common formatting rules
                  </div>
                  <div className="space-y-2.5 max-h-[220px] overflow-y-auto pr-1">
                    {Array.from(
                      new Set(commonFormattingRules.map((r) => r.category)),
                    ).map((category) => (
                      <div key={category}>
                        <div className="text-[10px] font-medium text-neutral-400 uppercase tracking-wider mb-1">
                          {category}
                        </div>
                        <div className="space-y-1">
                          {commonFormattingRules
                            .filter((r) => r.category === category)
                            .map((rule) => {
                              const alreadyAdded = formatting.customNotes.includes(
                                rule.label,
                              );
                              return (
                                <button
                                  key={rule.label}
                                  onClick={() => {
                                    if (alreadyAdded) return;
                                    const next = formatting.customNotes
                                      ? `${formatting.customNotes}\n- ${rule.label}`
                                      : `- ${rule.label}`;
                                    setFormatting({
                                      ...formatting,
                                      customNotes: next,
                                    });
                                  }}
                                  disabled={alreadyAdded}
                                  className={`w-full text-left flex items-center gap-2 px-2 py-1.5 rounded text-[12px] ${
                                    alreadyAdded
                                      ? "text-neutral-400 bg-neutral-100 cursor-default"
                                      : "text-neutral-700 hover:bg-white hover:border hover:border-neutral-200 border border-transparent"
                                  }`}
                                >
                                  {alreadyAdded ? (
                                    <Check className="w-3 h-3 text-emerald-600 flex-shrink-0" />
                                  ) : (
                                    <PlusIcon className="w-3 h-3 text-neutral-400 flex-shrink-0" />
                                  )}
                                  <span className="flex-1">{rule.label}</span>
                                </button>
                              );
                            })}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>

          <div className="flex justify-end gap-2 mt-5 pt-4 border-t border-neutral-100">
            <button
              onClick={() => setShowFormatting(false)}
              className="h-8 px-3 text-[12px] font-medium border border-neutral-200 rounded-md hover:bg-neutral-50"
            >
              Cancel
            </button>
            <button
              onClick={() => setShowFormatting(false)}
              className="h-8 px-3 text-[12px] font-medium bg-neutral-900 text-white rounded-md hover:bg-neutral-800"
            >
              Save preferences
            </button>
          </div>
        </Modal>
      )}

      {/* Action picker modal */}
      {showActionPicker && (
        <Modal title="Connect tools, actions and CVs" onClose={() => setShowActionPicker(false)}>
          <p className="text-[12px] text-neutral-500 mb-3">
            Selected tools are referenced by name in generated drafts. Pick the ones relevant to this flow.
          </p>

          <div className="relative mb-3">
            <Search className="w-3.5 h-3.5 text-neutral-400 absolute left-2.5 top-1/2 -translate-y-1/2" />
            <input
              placeholder="Search actions, subflows, CVs..."
              className="w-full h-8 pl-8 pr-3 text-[12.5px] border border-neutral-200 rounded-md focus:outline-none focus:border-neutral-900"
            />
          </div>

          <div className="space-y-1 max-h-[300px] overflow-y-auto pr-1">
            {availableActions.map((action) => {
              const Icon = action.icon;
              const selected = selectedActions.includes(action.name);
              return (
                <button
                  key={action.name}
                  onClick={() => toggleAction(action.name)}
                  className={`w-full flex items-center gap-2.5 p-2.5 rounded-md border text-left ${
                    selected
                      ? "border-neutral-900 bg-neutral-50"
                      : "border-neutral-200 hover:bg-neutral-50"
                  }`}
                >
                  <div className="w-7 h-7 rounded bg-white border border-neutral-200 flex items-center justify-center">
                    <Icon className="w-3.5 h-3.5 text-neutral-700" />
                  </div>
                  <div className="flex-1">
                    <div className="text-[12.5px] font-medium text-neutral-900">
                      {action.name}
                    </div>
                    <div className="text-[10.5px] text-neutral-500 uppercase tracking-wide">
                      {action.type}
                    </div>
                  </div>
                  <div
                    className={`w-4 h-4 rounded border flex items-center justify-center ${
                      selected
                        ? "border-neutral-900 bg-neutral-900"
                        : "border-neutral-300"
                    }`}
                  >
                    {selected && <Check className="w-2.5 h-2.5 text-white" />}
                  </div>
                </button>
              );
            })}
          </div>

          <div className="flex items-center justify-between mt-4 pt-4 border-t border-neutral-100">
            <span className="text-[12px] text-neutral-600">
              {selectedActions.length} selected
            </span>
            <button
              onClick={() => setShowActionPicker(false)}
              className="h-8 px-3 text-[12px] font-medium bg-neutral-900 text-white rounded-md hover:bg-neutral-800"
            >
              Done
            </button>
          </div>
        </Modal>
      )}

      {/* Versions modal */}
      {versionsModalId && (
        <Modal
          title={`${sections.find((s) => s.id === versionsModalId)?.label} version history`}
          onClose={() => setVersionsModalId(null)}
        >
          <p className="text-[12px] text-neutral-500 mb-4">
            Each generation is saved automatically. Restore a previous draft or compare across versions.
          </p>
          <div className="space-y-2">
            {mockVersions[versionsModalId].map((v) => (
              <div
                key={v.id}
                className={`p-3 rounded-md border ${
                  v.current
                    ? "border-neutral-900 bg-neutral-50"
                    : "border-neutral-200"
                }`}
              >
                <div className="flex items-center justify-between mb-1">
                  <div className="flex items-center gap-2">
                    <span className="text-[13px] font-semibold text-neutral-900">
                      {v.label}
                    </span>
                    {v.current && (
                      <span className="text-[9.5px] font-medium px-1.5 py-0.5 bg-emerald-50 text-emerald-700 rounded uppercase tracking-wide">
                        Live
                      </span>
                    )}
                  </div>
                  <span className="text-[11px] text-neutral-500">{v.date}</span>
                </div>
                <p className="text-[12px] text-neutral-600 mb-2">{v.note}</p>
                <div className="flex items-center gap-1.5">
                  {!v.current && (
                    <>
                      <button className="h-6 px-2 text-[11px] font-medium border border-neutral-200 rounded hover:bg-white">
                        Restore
                      </button>
                      <button className="h-6 px-2 text-[11px] font-medium border border-neutral-200 rounded hover:bg-white">
                        Compare
                      </button>
                    </>
                  )}
                  <button className="h-6 px-2 text-[11px] font-medium text-neutral-600 hover:text-neutral-900">
                    Preview
                  </button>
                </div>
              </div>
            ))}
          </div>
          <div className="flex justify-end mt-4 pt-4 border-t border-neutral-100">
            <button
              onClick={() => setVersionsModalId(null)}
              className="h-8 px-3 text-[12px] font-medium bg-neutral-900 text-white rounded-md hover:bg-neutral-800"
            >
              Close
            </button>
          </div>
        </Modal>
      )}

      {/* A/B test modal */}
      {abTestModalId && (
        <Modal
          title={`A/B test: ${sections.find((s) => s.id === abTestModalId)?.label}`}
          onClose={() => setAbTestModalId(null)}
        >
          <p className="text-[12px] text-neutral-500 mb-4">
            Run two versions of this section live and compare resolution rate, escalation rate, and CSAT.
          </p>

          <div className="space-y-3">
            <div className="p-3 border border-neutral-200 rounded-md">
              <div className="flex items-center justify-between mb-2">
                <div className="flex items-center gap-2">
                  <div className="w-6 h-6 rounded bg-violet-100 text-violet-700 text-[11px] font-semibold flex items-center justify-center">
                    A
                  </div>
                  <span className="text-[13px] font-semibold text-neutral-900">
                    Variant A — Current
                  </span>
                </div>
                <span className="text-[11px] text-neutral-500">50% traffic</span>
              </div>
              <p className="text-[11.5px] text-neutral-600">
                Latest drafted version
              </p>
            </div>

            <div className="p-3 border border-dashed border-neutral-300 rounded-md bg-neutral-50/50">
              <div className="flex items-center justify-between mb-2">
                <div className="flex items-center gap-2">
                  <div className="w-6 h-6 rounded bg-indigo-100 text-indigo-700 text-[11px] font-semibold flex items-center justify-center">
                    B
                  </div>
                  <span className="text-[13px] font-semibold text-neutral-900">
                    Variant B
                  </span>
                </div>
                <span className="text-[11px] text-neutral-500">50% traffic</span>
              </div>
              <select className="w-full h-8 text-[12px] border border-neutral-200 rounded px-2 bg-white">
                <option>Choose a version to test against...</option>
                {mockVersions[abTestModalId]
                  .filter((v) => !v.current)
                  .map((v) => (
                    <option key={v.id}>
                      {v.label} — {v.note}
                    </option>
                  ))}
                <option>Generate new variant</option>
              </select>
            </div>
          </div>

          <div className="mt-4 p-3 bg-neutral-50 rounded-md">
            <div className="text-[10.5px] font-semibold text-neutral-500 uppercase tracking-wide mb-2">
              Test settings
            </div>
            <div className="space-y-1.5 text-[12px]">
              <div className="flex justify-between">
                <span className="text-neutral-600">Duration</span>
                <span className="text-neutral-900">7 days</span>
              </div>
              <div className="flex justify-between">
                <span className="text-neutral-600">Min sample size</span>
                <span className="text-neutral-900">200 conversations / variant</span>
              </div>
              <div className="flex justify-between">
                <span className="text-neutral-600">Primary metric</span>
                <span className="text-neutral-900">Resolution rate</span>
              </div>
            </div>
          </div>

          <div className="flex justify-end gap-2 mt-4 pt-4 border-t border-neutral-100">
            <button
              onClick={() => setAbTestModalId(null)}
              className="h-8 px-3 text-[12px] font-medium border border-neutral-200 rounded-md hover:bg-neutral-50"
            >
              Cancel
            </button>
            <button
              onClick={() => setAbTestModalId(null)}
              className="h-8 px-3 text-[12px] font-medium bg-neutral-900 text-white rounded-md hover:bg-neutral-800 flex items-center gap-1.5"
            >
              <FlaskConical className="w-3 h-3" />
              Start test
            </button>
          </div>
        </Modal>
      )}
    </div>
  );
}

function Modal({ title, onClose, children, size = "md" }) {
  const sizeClass = size === "lg" ? "max-w-2xl" : "max-w-md";
  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center bg-neutral-900/40 backdrop-blur-sm p-4">
      <div className={`bg-white rounded-lg shadow-xl w-full ${sizeClass} max-h-[85vh] overflow-y-auto`}>
        <div className="flex items-center justify-between px-5 py-3.5 border-b border-neutral-100 sticky top-0 bg-white">
          <h3 className="text-[14px] font-semibold text-neutral-900">{title}</h3>
          <button
            onClick={onClose}
            className="p-1 hover:bg-neutral-100 rounded"
          >
            <X className="w-4 h-4 text-neutral-500" />
          </button>
        </div>
        <div className="p-5">{children}</div>
      </div>
    </div>
  );
}

function FormattingSelect({ label, value, onChange, options, help }) {
  return (
    <div className="mb-3">
      <label className="text-[11px] font-semibold text-neutral-500 uppercase tracking-wide mb-1.5 block">
        {label}
      </label>
      <div className="flex gap-1.5 flex-wrap">
        {options.map((opt) => (
          <button
            key={opt}
            onClick={() => onChange(opt)}
            className={`h-7 px-2.5 text-[12px] font-medium rounded-md border ${
              value === opt
                ? "border-neutral-900 bg-neutral-900 text-white"
                : "border-neutral-200 text-neutral-700 hover:bg-neutral-50"
            }`}
          >
            {opt}
          </button>
        ))}
      </div>
      {help && (
        <p className="text-[11px] text-neutral-500 mt-1.5">{help}</p>
      )}
    </div>
  );
}
